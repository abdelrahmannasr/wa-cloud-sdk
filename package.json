{
  "name": "@abdelrahmannasr-wa/cloud-api",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "version": "0.1.0",
  "description": "Zero-dependency, type-safe TypeScript SDK for the Meta WhatsApp Cloud API",
  "author": "AbdelRahman Nasr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdelrahmannasr/wa-cloud-sdk.git"
  },
  "homepage": "https://github.com/abdelrahmannasr/wa-cloud-sdk#readme",
  "bugs": {
    "url": "https://github.com/abdelrahmannasr/wa-cloud-sdk/issues"
  },
  "keywords": [
    "whatsapp",
    "cloud-api",
    "sdk",
    "typescript",
    "meta",
    "messaging",
    "webhooks",
    "templates"
  ],
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/errors/index.d.ts",
        "default": "./dist/errors/index.js"
      },
      "require": {
        "types": "./dist/errors/index.d.cts",
        "default": "./dist/errors/index.cjs"
      }
    },
    "./messages": {
      "import": {
        "types": "./dist/messages/index.d.ts",
        "default": "./dist/messages/index.js"
      },
      "require": {
        "types": "./dist/messages/index.d.cts",
        "default": "./dist/messages/index.cjs"
      }
    },
    "./webhooks": {
      "import": {
        "types": "./dist/webhooks/index.d.ts",
        "default": "./dist/webhooks/index.js"
      },
      "require": {
        "types": "./dist/webhooks/index.d.cts",
        "default": "./dist/webhooks/index.cjs"
      }
    },
    "./media": {
      "import": {
        "types": "./dist/media/index.d.ts",
        "default": "./dist/media/index.js"
      },
      "require": {
        "types": "./dist/media/index.d.cts",
        "default": "./dist/media/index.cjs"
      }
    },
    "./templates": {
      "import": {
        "types": "./dist/templates/index.d.ts",
        "default": "./dist/templates/index.js"
      },
      "require": {
        "types": "./dist/templates/index.d.cts",
        "default": "./dist/templates/index.cjs"
      }
    },
    "./phone-numbers": {
      "import": {
        "types": "./dist/phone-numbers/index.d.ts",
        "default": "./dist/phone-numbers/index.js"
      },
      "require": {
        "types": "./dist/phone-numbers/index.d.cts",
        "default": "./dist/phone-numbers/index.cjs"
      }
    },
    "./multi-account": {
      "import": {
        "types": "./dist/multi-account/index.d.ts",
        "default": "./dist/multi-account/index.js"
      },
      "require": {
        "types": "./dist/multi-account/index.d.cts",
        "default": "./dist/multi-account/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "pnpm run typecheck && pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}